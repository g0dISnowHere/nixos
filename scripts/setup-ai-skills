#!/usr/bin/env bash
set -euo pipefail

# Resolve repo root
if ! REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  echo "error: not inside a git repository" >&2
  exit 1
fi

# Ensure submodules are initialized
git -C "$REPO_ROOT" submodule update --init --recursive \
  third-party/skills/mattpocock-skills \
  third-party/skills/stop-slop \
  third-party/skills/caveman

# Symlink all skills into each target directory
target_dirs=("$HOME/.agents/skills" "$HOME/.claude/skills")

for target_dir in "${target_dirs[@]}"; do
  mkdir -p "$target_dir"

  # mattpocock skills: every non-deprecated SKILL.md at depth 3 (skills/<category>/<name>/SKILL.md)
  while IFS= read -r skill_md; do
    skill_dir="$(dirname "$skill_md")"
    name="$(basename "$skill_dir")"
    ln -sfn "$skill_dir" "$target_dir/$name"
    echo "linked $name -> $skill_dir"
  done < <(find "$REPO_ROOT/third-party/skills/mattpocock-skills/skills" \
      -mindepth 3 -maxdepth 3 -name SKILL.md -not -path '*/deprecated/*' \
      | sort)

  # stop-slop: symlink the whole directory (SKILL.md + references/ are at root)
  ln -sfn "$REPO_ROOT/third-party/skills/stop-slop" "$target_dir/stop-slop"
  echo "linked stop-slop -> $REPO_ROOT/third-party/skills/stop-slop"

  # caveman skills: flat layout — SKILL.md at depth 2 (skills/<name>/SKILL.md)
  while IFS= read -r skill_md; do
    skill_dir="$(dirname "$skill_md")"
    name="$(basename "$skill_dir")"
    ln -sfn "$skill_dir" "$target_dir/$name"
    echo "linked $name -> $skill_dir"
  done < <(find "$REPO_ROOT/third-party/skills/caveman/plugins/caveman/skills" \
      -mindepth 2 -maxdepth 2 -name SKILL.md \
      | sort)
done
