#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=secrets-lib/inspect.sh
source "${script_dir}/secrets-lib/inspect.sh"
# shellcheck source=secrets-lib/ui.sh
source "${script_dir}/secrets-lib/ui.sh"

usage() {
  cat <<'EOF'
Usage: scripts/secrets [command] [options]

Operator-facing SOPS orchestrator for this repo.

Commands:
  doctor         Inspect current state and guide the next action (default)
  sync-policy    Render .sops.yaml from flake/secrets-policy.nix
  validate       Backward-compatible alias for validate-access
  validate-policy
                 Validate policy ownership and rendered config drift
  validate-access
                 Validate operator and/or host secret access
  create         Create a new encrypted secret in an existing scope
  add-host       Add a new host with explicit user-scope membership
  register-host  Refresh an existing host recipient and rekey its secrets
  retire-host    Remove a host from policy and rekey shared secrets
  user-scope     Create, update, or retire users.<name> membership policy
  recover-access Recover operator access from a working machine

Doctor options:
  --fix          Enter guided remediation mode after inspection
  --full-test    Allow privileged inspection checks that may prompt for sudo
  --host NAME    Override the host alias
  -h, --help     Show this help

Examples:
  scripts/secrets
  scripts/secrets doctor --fix
  scripts/secrets doctor --full-test
  scripts/secrets validate-access --actor all
  scripts/secrets validate-policy
  scripts/secrets sync-policy --check
  scripts/secrets create --scope services.fleet-test --name registry.env
  scripts/secrets add-host --host alhena --user-scope djoolz
  scripts/secrets register-host --host alhena
  scripts/secrets user-scope --user djoolz --add-host alhena
  scripts/secrets retire-host --host alhena --dry-run
  scripts/secrets recover-access --host alhena --target-operator-recipient age1...
EOF
}

doctor_fix=0
doctor_host=""
doctor_full_test=0

doctor_usage() {
  cat <<'EOF'
Usage: scripts/secrets doctor [--fix] [--host NAME]
EOF
}

run_validate() {
  bash "${script_dir}/secrets-workflows/validate.sh" "$@"
}

run_validate_policy() {
  bash "${script_dir}/secrets-workflows/validate-policy.sh" "$@"
}

run_sync_policy() {
  bash "${script_dir}/secrets-workflows/sync-policy.sh" "$@"
}

run_register_host() {
  bash "${script_dir}/secrets-workflows/register-host.sh" "$@"
}

run_add_host() {
  bash "${script_dir}/secrets-workflows/add-host.sh" "$@"
}

run_create_secret() {
  bash "${script_dir}/secrets-workflows/create-secret.sh" "$@"
}

run_retire_host() {
  bash "${script_dir}/secrets-workflows/retire-host.sh" "$@"
}

run_recover_access() {
  bash "${script_dir}/secrets-workflows/recover-access.sh" "$@"
}

run_user_scope() {
  bash "${script_dir}/secrets-workflows/user-scope.sh" "$@"
}

run_bootstrap_host_key() {
  "${script_dir}/ssh-pubkey-to-age.sh"
}

doctor_inspect() {
  local host_name="$1"

  SECRETS_DOCTOR_STATE="healthy"
  SECRETS_DOCTOR_REASON="All current preflight checks passed."

  if [[ ! -f "${SECRETS_SOPS_CONFIG}" ]]; then
    SECRETS_DOCTOR_STATE="missing_config"
    SECRETS_DOCTOR_REASON="Missing ${SECRETS_SOPS_CONFIG}"
    return
  fi

  if [[ "${SECRETS_POLICY_ERROR_COUNT}" -gt 0 ]]; then
    SECRETS_DOCTOR_STATE="policy_invalid"
    SECRETS_DOCTOR_REASON="The secrets policy has validation errors."
    return
  fi

  if [[ "${SECRETS_POLICY_DRIFT}" -eq 1 ]]; then
    SECRETS_DOCTOR_STATE="policy_drift"
    SECRETS_DOCTOR_REASON=".sops.yaml does not match the rendered secrets policy."
    return
  fi

  if [[ "${SECRETS_HOST_KEY_EXISTS}" -ne 1 ]]; then
    SECRETS_DOCTOR_STATE="missing_host_key"
    SECRETS_DOCTOR_REASON="Host key ${SECRETS_HOST_KEY_FILE} does not exist yet."
    return
  fi

  if [[ "${SECRETS_HOST_ALIAS_EXISTS}" -ne 1 ]]; then
    SECRETS_DOCTOR_STATE="new_host"
    SECRETS_DOCTOR_REASON="Host alias ${host_name} is not present in .sops.yaml yet."
    return
  fi

  if [[ "${SECRETS_OPERATOR_KEY_EXISTS}" -ne 1 ]]; then
    if [[ "${SECRETS_HOST_CAN_DECRYPT}" -eq 1 ]]; then
      SECRETS_DOCTOR_STATE="missing_operator_key"
      SECRETS_DOCTOR_REASON="Operator key ${SECRETS_OPERATOR_KEY_FILE} is missing or unreadable."
    else
      SECRETS_DOCTOR_STATE="recovery_required"
      SECRETS_DOCTOR_REASON="This machine cannot decrypt the relevant secrets with either its operator key or host key."
    fi
    return
  fi

  if [[ "${SECRETS_OPERATOR_CAN_DECRYPT}" -ne 1 ]]; then
    if [[ "${SECRETS_HOST_CAN_DECRYPT}" -eq 1 ]]; then
      SECRETS_DOCTOR_STATE="operator_blocked_but_host_ok"
      SECRETS_DOCTOR_REASON="The operator key cannot decrypt the current target secrets, but the host key still can."
    else
      SECRETS_DOCTOR_STATE="recovery_required"
      SECRETS_DOCTOR_REASON="This machine cannot decrypt the relevant secrets with either its operator key or host key."
    fi
    return
  fi

  if [[ "${SECRETS_HOST_RECIPIENT_MATCH_STATUS}" == "no" ]]; then
    SECRETS_DOCTOR_STATE="host_recipient_mismatch"
    SECRETS_DOCTOR_REASON="The host key does not match the configured recipient."
    return
  fi

  if [[ "${SECRETS_HOST_CAN_DECRYPT}" -ne 1 ]]; then
    SECRETS_DOCTOR_STATE="host_access_broken"
    SECRETS_DOCTOR_REASON="The host key cannot decrypt all intended secrets."
    return
  fi

  if [[ "${SECRETS_HOST_RECIPIENT_MATCH_STATUS}" == "unknown" ]]; then
    SECRETS_DOCTOR_REASON="All access checks passed, but recipient verification is partial because the host public key could not be read directly."
  fi
}

doctor_summary() {
  secrets_ui_section "Secrets Doctor"
  printf 'Host alias: %s\n' "${SECRETS_HOST_NAME}"
  printf 'Repository: %s\n' "${SECRETS_REPO_ROOT}"
  printf '\n'

  secrets_ui_kv "Operator key file" "${SECRETS_OPERATOR_KEY_FILE}"
  secrets_ui_kv "Operator key presence" "${SECRETS_OPERATOR_KEY_PRESENCE_STATUS}"
  secrets_ui_kv "Operator key inspection" "${SECRETS_OPERATOR_KEY_INSPECTION_STATUS}"
  if [[ -n "${SECRETS_OPERATOR_PUBLIC_KEYS:-}" ]]; then
    secrets_ui_kv "Operator public keys" "${SECRETS_OPERATOR_PUBLIC_KEYS}"
  fi

  secrets_ui_kv "Host key file" "${SECRETS_HOST_KEY_FILE}"
  secrets_ui_kv "Host key presence" "${SECRETS_HOST_KEY_PRESENCE_STATUS}"
  secrets_ui_kv "Host key inspection" "${SECRETS_HOST_KEY_INSPECTION_STATUS}"
  if [[ -n "${SECRETS_HOST_PUBLIC_KEY:-}" ]]; then
    secrets_ui_kv "Host public key" "${SECRETS_HOST_PUBLIC_KEY}"
  fi

  if [[ "${SECRETS_HOST_ALIAS_EXISTS}" -eq 1 ]]; then
    secrets_ui_kv "Configured host recipient" "${SECRETS_CONFIGURED_HOST_RECIPIENT}"
    secrets_ui_kv "Recipient match" "${SECRETS_HOST_RECIPIENT_MATCH_STATUS}"
  else
    secrets_ui_kv "Configured host recipient" "host missing from policy"
  fi

  secrets_ui_kv "Policy errors" "${SECRETS_POLICY_ERROR_COUNT}"
  if [[ "${SECRETS_POLICY_DRIFT}" -eq 1 ]]; then
    secrets_ui_kv "Policy drift" "yes"
  else
    secrets_ui_kv "Policy drift" "no"
  fi
  secrets_ui_kv "Relevant secrets" "${SECRETS_RELEVANT_SECRET_COUNT}"
  secrets_ui_kv "Operator key decryptability" "${SECRETS_OPERATOR_KEY_DECRYPT_STATUS}"
  secrets_ui_kv "Operator decrypt check" "${SECRETS_OPERATOR_DECRYPT_STATUS}"
  secrets_ui_kv "Host key decryptability" "${SECRETS_HOST_KEY_DECRYPT_STATUS}"
  secrets_ui_kv "Host decrypt check" "${SECRETS_HOST_DECRYPT_STATUS}"

  printf '\n'
  secrets_ui_note "Detected state: ${SECRETS_DOCTOR_STATE}"
  secrets_ui_note "${SECRETS_DOCTOR_REASON}"

  if [[ "${SECRETS_RELEVANT_SECRET_COUNT}" -gt 0 ]]; then
    printf '\nAffected secrets:\n'
    printf '  %s\n' "${SECRETS_RELEVANT_SECRETS[@]#${SECRETS_REPO_ROOT}/}"
  fi

  if [[ "${#SECRETS_RELEVANT_RECIPIENTS[@]}" -gt 0 ]]; then
    printf '\nEmbedded recipients in those secrets:\n'
    printf '  %s\n' "${SECRETS_RELEVANT_RECIPIENTS[@]}"
  fi

  if [[ "${SECRETS_POLICY_ERROR_COUNT}" -gt 0 ]]; then
    printf '\nPolicy errors:\n'
    printf '  %s\n' "${SECRETS_POLICY_ERRORS[@]}"
  fi
}

doctor_suggest() {
  case "${SECRETS_DOCTOR_STATE}" in
    policy_invalid)
      printf '\nSuggested next step: scripts/secrets validate-policy\n'
      ;;
    policy_drift)
      printf '\nSuggested next step: scripts/secrets sync-policy --diff\n'
      ;;
    missing_config)
      printf '\nSuggested next step: scripts/secrets sync-policy\n'
      ;;
    missing_host_key)
      printf '\nSuggested next step: scripts/secrets doctor --fix\n'
      ;;
    new_host)
      printf '\nSuggested next step: scripts/secrets doctor --fix\n'
      ;;
    missing_operator_key|operator_blocked_but_host_ok)
      printf '\nSuggested next step: provide a working operator age key, then run scripts/secrets validate-access\n'
      ;;
    recovery_required)
      printf '\nSuggested next step: recover from another machine or backup that still matches an embedded recipient\n'
      printf 'Guided option on a working machine:\n'
      printf '  scripts/secrets recover-access\n'
      if [[ -n "${SECRETS_OPERATOR_PUBLIC_KEYS:-}" ]]; then
        printf 'Suggested recovery command on a working machine:\n'
        printf '  scripts/secrets recover-access --host %s --target-operator-recipient %s\n' \
          "${SECRETS_HOST_NAME}" "${SECRETS_OPERATOR_PUBLIC_KEYS%%,*}"
      fi
      ;;
    host_recipient_mismatch|host_access_broken)
      printf '\nSuggested next step: scripts/secrets doctor --fix\n'
      ;;
    healthy)
      if [[ "${SECRETS_HOST_KEY_INSPECTION_STATUS}" == "direct access unavailable" \
        || "${SECRETS_HOST_RECIPIENT_MATCH_STATUS}" == "unknown" ]]; then
        printf '\nSuggested next step: scripts/secrets doctor --full-test\n'
        printf 'That will allow a privileged inspection pass to confirm host-key details directly.\n'
      else
        printf '\nSuggested next step: scripts/secrets validate-access\n'
      fi
      ;;
    *)
      printf '\nSuggested next step: scripts/secrets validate-access\n'
      ;;
  esac
}

doctor_fix_flow() {
  local choice=""

  case "${SECRETS_DOCTOR_STATE}" in
    policy_invalid)
      run_validate_policy
      ;;
    policy_drift)
      choice="$(secrets_ui_choose \
        "Rendered policy and committed .sops.yaml differ. Choose the next action:" \
        "sync-policy" \
        "show-diff" \
        "abort")"
      case "${choice}" in
        sync-policy)
          run_sync_policy
          ;;
        show-diff)
          run_sync_policy --diff
          ;;
      esac
      ;;
    missing_config)
      run_sync_policy
      ;;
    missing_host_key)
      choice="$(secrets_ui_choose \
        "Onboarding keys are incomplete. Choose the next action:" \
        "bootstrap-onboarding-keys" \
        "validate-only" \
        "abort")"
      case "${choice}" in
        bootstrap-onboarding-keys)
          run_bootstrap_host_key
          ;;
        validate-only)
          run_validate --actor operator --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    new_host)
      choice="$(secrets_ui_choose \
        "This looks like a new host. Choose the next action:" \
        "bootstrap-onboarding-keys" \
        "onboard-host" \
        "validate-only" \
        "abort")"
      case "${choice}" in
        bootstrap-onboarding-keys)
          run_bootstrap_host_key
          ;;
        onboard-host)
          run_add_host --host "${SECRETS_HOST_NAME}"
          ;;
        validate-only)
          run_validate --actor operator --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    missing_operator_key|operator_blocked_but_host_ok)
      choice="$(secrets_ui_choose \
        "Operator access is blocked. Choose the next action:" \
        "validate-only" \
        "abort")"
      case "${choice}" in
        validate-only)
          run_validate --actor operator --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    recovery_required)
      choice="$(secrets_ui_choose \
        "This machine cannot decrypt the relevant secrets locally. Choose the next action:" \
        "show-recovery-steps" \
        "run-recovery-workflow" \
        "validate-only" \
        "abort")"
      case "${choice}" in
        show-recovery-steps)
          printf '\nRecovery workflow:\n'
          printf '  1. Move to a known-good machine or backup that can still decrypt the shared secrets.\n'
          printf '  2. Use the embedded recipients above to identify which key on that machine should work.\n'
          printf '  3. Run scripts/secrets recover-access there to rekey the affected secrets.\n'
          printf '  4. Return here and run scripts/secrets validate-access.\n'
          printf '\nGuided option on the working machine:\n'
          printf '  scripts/secrets recover-access\n'
          if [[ -n "${SECRETS_OPERATOR_PUBLIC_KEYS:-}" ]]; then
            printf '\nSuggested command on the working machine:\n'
            printf '  scripts/secrets recover-access --host %s --target-operator-recipient %s\n' \
              "${SECRETS_HOST_NAME}" "${SECRETS_OPERATOR_PUBLIC_KEYS%%,*}"
          fi
          ;;
        run-recovery-workflow)
          run_recover_access --host "${SECRETS_HOST_NAME}"
          ;;
        validate-only)
          run_validate --actor all --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    host_recipient_mismatch|host_access_broken)
      choice="$(secrets_ui_choose \
        "Host registration needs attention. Choose the next action:" \
        "refresh-registration" \
        "validate-only" \
        "abort")"
      case "${choice}" in
        refresh-registration)
          run_register_host --host "${SECRETS_HOST_NAME}" --force-host-rotate
          ;;
        validate-only)
          run_validate --actor all --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    healthy)
      choice="$(secrets_ui_choose \
        "Secret access looks healthy. Choose the next action:" \
        "validate" \
        "refresh-registration" \
        "abort")"
      case "${choice}" in
        validate)
          run_validate --actor all --host "${SECRETS_HOST_NAME}"
          ;;
        refresh-registration)
          run_register_host --host "${SECRETS_HOST_NAME}"
          ;;
      esac
      ;;
    *)
      secrets_ui_error "No guided remediation is defined for state ${SECRETS_DOCTOR_STATE}."
      return 1
      ;;
  esac
}

run_doctor() {
  local host_name="${doctor_host:-$(hostname -s)}"

  if [[ "${doctor_full_test}" -eq 1 ]]; then
    export SECRETS_ALLOW_SUDO_PROMPT=1
  fi

  secrets_inspect_state "${host_name}"
  doctor_inspect "${host_name}"
  doctor_summary

  if [[ "${doctor_fix}" -eq 1 ]]; then
    printf '\n'
    doctor_fix_flow
  else
    doctor_suggest
  fi
}

parse_doctor_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix)
        doctor_fix=1
        shift
        ;;
      --full-test)
        doctor_full_test=1
        shift
        ;;
      --host)
        doctor_host="${2:?missing value for --host}"
        shift 2
        ;;
      -h|--help)
        doctor_usage
        exit 0
        ;;
      *)
        printf 'Unknown doctor argument: %s\n' "$1" >&2
        doctor_usage >&2
        exit 1
        ;;
    esac
  done
}

main() {
  local command="${1:-doctor}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "${command}" in
    doctor)
      parse_doctor_args "$@"
      run_doctor
      ;;
    validate)
      run_validate "$@"
      ;;
    validate-policy)
      run_validate_policy "$@"
      ;;
    validate-access)
      run_validate "$@"
      ;;
    create)
      run_create_secret "$@"
      ;;
    add-host)
      run_add_host "$@"
      ;;
    retire-host)
      run_retire_host "$@"
      ;;
    sync-policy)
      run_sync_policy "$@"
      ;;
    register-host)
      run_register_host "$@"
      ;;
    user-scope)
      run_user_scope "$@"
      ;;
    recover-access)
      run_recover_access "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      printf 'Unknown command: %s\n\n' "${command}" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
