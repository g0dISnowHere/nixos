#!/usr/bin/env bash
# Pre-commit hook for NixOS flake configuration
# Runs validation before allowing commits

set -e

# Prevent running as root (would create root-owned git files)
if [ "$(id -u)" = "0" ]; then
    echo "❌ Pre-commit hook must run as regular user, not root"
    echo "   Do not use 'sudo git commit' or run nix commands with sudo"
    exit 1
fi

echo "🔍 Running pre-commit checks..."
echo ""

# === Format Code ===
echo "1️⃣  Formatting code with nix fmt..."
# Capture the currently staged files so we can re-stage only those.
staged_files_file="/tmp/pre-commit-staged-files.txt"
git diff --name-only --cached > "$staged_files_file"
cleanup_staged_file() {
    rm -f "$staged_files_file"
}
trap cleanup_staged_file EXIT
nix fmt
if git diff-index --quiet HEAD --; then
    echo "   ✓ No formatting changes"
else
    echo "   ℹ️  Code was reformatted, staging changes..."
    # Re-stage only the files that were staged before formatting.
    if [ -s "$staged_files_file" ]; then
        xargs -d '\n' git add -- < "$staged_files_file"
    fi
fi
echo ""

# === Validate Configuration ===
echo "2️⃣  Running validation script..."
if sh validate.sh > /tmp/validate-output.txt 2>&1; then
    cat /tmp/validate-output.txt | grep "^  ✓\|^  ✗\|^==="
    echo ""
else
    echo ""
    cat /tmp/validate-output.txt
    echo ""
    echo "❌ Validation failed! Commit aborted."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
echo ""
