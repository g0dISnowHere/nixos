#!/usr/bin/env bash
# Pre-commit hook for NixOS flake configuration
# Runs validation before allowing commits

set -e

# Prevent running as root (would create root-owned git files)
if [ "$(id -u)" = "0" ]; then
    echo "❌ Pre-commit hook must run as regular user, not root"
    echo "   Do not use 'sudo git commit' or run nix commands with sudo"
    exit 1
fi

echo "🔍 Running pre-commit checks..."
echo ""

# Capture the currently staged files so we can re-stage only those.
staged_files_file="/tmp/pre-commit-staged-files.txt"
git diff --name-only --cached > "$staged_files_file"
has_nix_files=0
has_markdown_files=0
has_shell_files=0

if grep -E '\.nix$' "$staged_files_file" | grep -vq -x "dconf.nix"; then
    has_nix_files=1
fi

if grep -Eq '\.md$' "$staged_files_file"; then
    has_markdown_files=1
fi

if grep -Eq '(^|/)[^/]+\.sh$|^scripts/secrets$|^\.githooks/pre-commit$' "$staged_files_file"; then
    has_shell_files=1
fi

if [ "$has_nix_files" -eq 0 ] && [ "$has_markdown_files" -eq 0 ] && [ "$has_shell_files" -eq 0 ]; then
    echo "   ℹ️  No staged .nix, .md, or shell files requiring repo checks; skipping."
    exit 0
fi
cleanup_staged_file() {
    rm -f "$staged_files_file"
}
trap cleanup_staged_file EXIT

# === Format Code ===
if [ "$has_nix_files" -eq 1 ]; then
    echo "1️⃣  Formatting code with nix fmt..."
    nix fmt
    if git diff-index --quiet HEAD --; then
        echo "   ✓ No formatting changes"
    else
        echo "   ℹ️  Code was reformatted, staging changes..."
        # Re-stage only the files that were staged before formatting.
        if [ -s "$staged_files_file" ]; then
            while IFS= read -r path; do
                if [ -e "$path" ] || [ -L "$path" ]; then
                    git add -- "$path"
                else
                    if git ls-files --error-unmatch -- "$path" >/dev/null 2>&1; then
                        git add -u -- "$path"
                    fi
                fi
            done < "$staged_files_file"
        fi
    fi
else
    echo "1️⃣  No staged .nix files; skipping nix fmt."
fi
echo ""

# === Validate Configuration ===
echo "2️⃣  Running validation script..."
if sh ./scripts/validate-fast.sh > /tmp/validate-output.txt 2>&1; then
    cat /tmp/validate-output.txt | grep "^  ✓\|^  ✗\|^==="
    echo ""
else
    echo ""
    cat /tmp/validate-output.txt
    echo ""
    echo "❌ Validation failed! Commit aborted."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
echo ""
